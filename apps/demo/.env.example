VITE_LIVEKIT_URL=wss://replace-me.livekit.cloud
VITE_DEFAULT_MODEL=waypoint

# Preferred for local development. Vite proxies /api to the coordinator so the browser
# does not need cross-origin access to the coordinator directly.
VITE_COORDINATOR_PROXY_TARGET=http://127.0.0.1:8080
COORDINATOR_API_KEY=replace-me

# Alternative direct mode for a deployed demo behind the same origin or a gateway that adds CORS.
# VITE_COORDINATOR_BASE_URL=https://coordinator.example.com
# VITE_COORDINATOR_API_KEY=replace-me
