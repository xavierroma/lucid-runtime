            ]
          },
          "output": {
            "type": "string"
          }
        },
        "required": [
          "output",
          "max_rate_hz"
        ],
        "type": "object"
      },
      "description": "Throttle a named output to a maximum publish rate in Hertz.",
      "mode": "state",
      "name": "lucid.runtime.set_output_rate"
