MODAL_APP_ENTRYPOINT=yume_modal_example.modal_app

MODAL_APP_NAME=lucid-runtime-worker
MODAL_DISPATCH_TOKEN=replace-me
MODAL_GPU=A100
MODAL_MIN_CONTAINERS=1
MODAL_SCALEDOWN_WINDOW_SECS=1200
MODAL_MODEL_VOLUME=lucid-yume-models
MODAL_HF_CACHE_VOLUME=lucid-hf-cache

LIVEKIT_URL=wss://replace-me.livekit.cloud
LIVEKIT_API_KEY=replace-me
LIVEKIT_API_SECRET=replace-me

YUME_MODEL_DIR=/models/Yume-5B-720P
HF_HOME=/cache/huggingface
HF_TOKEN=

WM_ENGINE=yume
WM_LIVEKIT_MODE=real
WM_STATUS_TOPIC=wm.status
WM_FRAME_WIDTH=1280
WM_FRAME_HEIGHT=720
WM_TARGET_FPS=2
WM_MAX_QUEUE_FRAMES=32

YUME_CHUNK_FRAMES=8
YUME_BASE_PROMPT=POV of a character walking in a minecraft scene
