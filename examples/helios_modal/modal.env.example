MODAL_APP_ENTRYPOINT=helios_modal_example.modal_app

MODAL_APP_NAME=lucid-helios-worker
MODAL_DISPATCH_TOKEN=replace-me
MODAL_GPU=H100
MODAL_MIN_CONTAINERS=0
MODAL_SCALEDOWN_WINDOW_SECS=1200
MODAL_STARTUP_TIMEOUT_SECS=2400
MODAL_MODEL_VOLUME=lucid-helios-models
MODAL_HF_CACHE_VOLUME=lucid-hf-cache

LIVEKIT_URL=wss://replace-me.livekit.cloud
LIVEKIT_API_KEY=replace-me
LIVEKIT_API_SECRET=replace-me

HELIOS_MODEL_SOURCE=/models/Helios-Distilled
HELIOS_DEFAULT_PROMPT="A vibrant tropical fish swimming gracefully among colorful coral reefs in a clear, turquoise ocean."
HELIOS_NEGATIVE_PROMPT="Bright tones, overexposed, static, blurred details, subtitles, style, works, paintings, images, static, overall gray, worst quality, low quality, JPEG compression residue, ugly, incomplete, extra fingers, poorly drawn hands, poorly drawn faces, deformed, disfigured, misshapen limbs, fused fingers, still picture, messy background, three legs, many people in the background, walking backwards"
HELIOS_FRAME_WIDTH=640
HELIOS_FRAME_HEIGHT=384
HELIOS_OUTPUT_FPS=24
HELIOS_CHUNK_FRAMES=33
HELIOS_GUIDANCE_SCALE=1.0
HELIOS_PYRAMID_STEPS=2,2,2
HELIOS_AMPLIFY_FIRST_CHUNK=1
HELIOS_ENABLE_GROUP_OFFLOADING=0
HELIOS_GROUP_OFFLOADING_TYPE=leaf_level
HELIOS_MAX_SEQUENCE_LENGTH=512
HF_HOME=/cache/huggingface
HF_TOKEN=

WM_ENGINE=helios
WM_LIVEKIT_MODE=real
WM_STATUS_TOPIC=wm.status
WM_MAX_QUEUE_FRAMES=32
