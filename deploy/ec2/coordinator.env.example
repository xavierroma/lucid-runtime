API_KEY=replace-with-random-public-api-key
WORKER_INTERNAL_TOKEN=replace-with-random-internal-callback-token
LIVEKIT_API_KEY=replace-with-livekit-api-key
LIVEKIT_API_SECRET=replace-with-livekit-api-secret

# Public URL that the Modal worker can call back into.
COORDINATOR_CALLBACK_BASE_URL=https://coordinator.example.com
COORDINATOR_MODELS_FILE=/app/config/coordinator.models.json
COORDINATOR_BIND_ADDR=0.0.0.0:8080

# Workstation-driven deployment settings used by deploy/ec2/deploy.sh.
COORDINATOR_IMAGE_REPOSITORY=ghcr.io/replace-me/lucid-coordinator
# Optional fixed tag. If unset, deploy.sh uses the current git sha, adds -dirty for local changes,
# or falls back to a timestamp outside git.
# COORDINATOR_IMAGE_TAG=main
# Alternative to repository + tag:
# COORDINATOR_IMAGE=ghcr.io/replace-me/lucid-coordinator:manual-tag
# Optional local AWS profile used when COORDINATOR_IMAGE_REPOSITORY points at ECR.
# AWS_PROFILE=lucid
EC2_HOST=ec2-xx-xx-xx-xx.us-west-2.compute.amazonaws.com
# Optional transport override. `auto` prefers SSM for managed instances and falls back to SSH.
# EC2_DEPLOY_TRANSPORT=auto
# Optional explicit instance id for SSM transport.
# EC2_INSTANCE_ID=i-0123456789abcdef0
# EC2_USER=ec2-user
# EC2_SSH_PORT=22
# EC2_SSH_KEY_PATH=~/.ssh/your-key.pem
# EC2_REMOTE_DIR=/home/ec2-user/lucid-runtime/deploy/ec2
# EC2_MODELS_FILE=deploy/ec2/coordinator.models.json
# HOST_PORT=8080
# Optional command run on the EC2 host before docker pull. If the image repo is ECR and this is unset,
# deploy.sh automatically runs `aws ecr get-login-password ... | docker login ...` on the instance.
# EC2_DOCKER_LOGIN_COMMAND=aws ecr get-login-password --region us-west-2 | docker login --username AWS --password-stdin <account>.dkr.ecr.us-west-2.amazonaws.com
# Optional AWS profile on the EC2 host for automatic ECR login.
# EC2_AWS_PROFILE=default
