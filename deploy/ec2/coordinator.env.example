API_KEY=replace-with-random-public-api-key
WORKER_INTERNAL_TOKEN=replace-with-random-internal-callback-token
LIVEKIT_API_KEY=replace-with-livekit-api-key
LIVEKIT_API_SECRET=replace-with-livekit-api-secret

# Must match the deployed Modal worker model preset: yume or waypoint.
WM_MODEL_NAME=waypoint

WORKER_ID=wm-worker-1
MODAL_DISPATCH_BASE_URL=https://replace-me.modal.run
MODAL_DISPATCH_TOKEN=replace-with-same-modal-dispatch-token
# Public URL that the Modal worker can call back into.
COORDINATOR_CALLBACK_BASE_URL=https://coordinator.example.com
COORDINATOR_BIND_ADDR=0.0.0.0:8080
# Waypoint cold starts can take several minutes while the worker loads and autotunes kernels.
SESSION_STARTUP_TIMEOUT_SECS=900
SESSION_MAX_DURATION_SECS=3600
SESSION_CANCEL_GRACE_SECS=30
WORKER_HEARTBEAT_TIMEOUT_SECS=15
